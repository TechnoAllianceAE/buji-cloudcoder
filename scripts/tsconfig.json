{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "types": [
      "node"
    ],
    "baseUrl": "..",
    "noImplicitAny": false,
    "paths": {
      "@bcp/internal": [
        "./packages/internal/src/index.ts"
      ],
      "@bcp/internal/*": [
        "./packages/internal/src/*"
      ],
      "@bcp/sdk": [
        "./sdk/src/index.ts"
      ],
      "@bcp/sdk/*": [
        "./sdk/src/*"
      ],
      "drizzle-orm": [
        "./packages/internal/node_modules/drizzle-orm"
      ],
      "drizzle-orm/*": [
        "./packages/internal/node_modules/drizzle-orm/*"
      ]
    }
  },
  "include": [
    "**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "generate-ci-env.ts",
    "ft-file-selection",
    "tmux/tmux-viewer"
  ]
}
