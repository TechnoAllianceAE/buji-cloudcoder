{
  "name": "@bcp/code-map",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./*": {
      "import": "./src/*.ts",
      "types": "./src/*.ts",
      "default": "./src/*.ts"
    }
  },
  "scripts": {
    "typecheck": "tsc --noEmit -p .",
    "test": "vitest run"
  },
  "sideEffects": false,
  "dependencies": {
    "@vscode/tree-sitter-wasm": "0.1.4",
    "web-tree-sitter": "0.25.6"
  },
  "devDependencies": {}
}
