# BujiCoderPlus (BCP) — Environment Variables
# Copy this file to .env and fill in values.

# ─── Required ────────────────────────────────────────────────────────────────

# Gateway URL (where BCP connects for auth and LLM routing)
NEXT_PUBLIC_BCP_APP_URL=https://ent.bujicoder.com

# Environment: dev | test | prod
NEXT_PUBLIC_CB_ENVIRONMENT=dev

# ─── Optional Overrides ─────────────────────────────────────────────────────

# Override API URL (takes precedence over NEXT_PUBLIC_BCP_APP_URL)
# BCP_API_URL=https://ent.bujicoder.com

# API key for headless/CI usage (bypasses interactive login)
# BCP_API_KEY=

# Build mode flag (used during compilation)
# BCP_MODE=false

# ─── Unused / Legacy (from Codebuff fork, safe to ignore) ───────────────────

# These are still in the env schema but not used by BCP:
# NEXT_PUBLIC_SUPPORT_EMAIL=support@bujicoder.com
# NEXT_PUBLIC_POSTHOG_API_KEY=disabled
# NEXT_PUBLIC_POSTHOG_HOST_URL=https://localhost
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=disabled
# NEXT_PUBLIC_STRIPE_CUSTOMER_PORTAL=https://localhost
# NEXT_PUBLIC_WEB_PORT=3000
