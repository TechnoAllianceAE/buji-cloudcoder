{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "types": [
      "node"
    ],
    "baseUrl": ".",
    "skipLibCheck": true,
    "paths": {
      "@bcp/sdk": [
        "../sdk/src/index.ts"
      ],
      "@bcp/sdk/*": [
        "../sdk/src/*"
      ]
    }
  },
  "include": [
    "**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "test-repos"
  ]
}
