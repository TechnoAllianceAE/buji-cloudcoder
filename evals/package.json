{
  "name": "@bcp/evals",
  "version": "1.0.0",
  "description": "Evaluation scripts for BujiCoderPlus",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts"
    }
  },
  "scripts": {
    "typecheck": "tsc --noEmit -p .",
    "test": "vitest run",
    "test:manifold": "vitest run manifold.test.ts",
    "test:pglite": "vitest run pglite-demo.test.ts",
    "test:swe-bench": "vitest run swe-bench.test.ts",
    "test:e2e-cat-app": "tsx e2e-cat-app-script.ts",
    "gen-repo-eval": "tsx git-evals/gen-repo-eval.ts",
    "run-single-eval": "tsx git-evals/run-single-eval.ts --eval-file git-evals/eval-manifold.json --commit-sha ebabf7796a92ce8ece8e2452b0f3f896a513ba0e",
    "run-git-evals": "tsx git-evals/run-git-evals.ts",
    "run-eval-set": "tsx git-evals/run-eval-set.ts",
    "run-buffbench": "tsx buffbench/main.ts",
    "run-buffbench-nightly": "tsx buffbench/main-nightly.ts",
    "trigger-buffbench": "tsx scripts/trigger-buffbench.ts"
  },
  "sideEffects": false,
  "dependencies": {
    "@anthropic-ai/claude-code": "^2.0.56",
    "@bcp/code-map": "workspace:*",
    "@bcp/common": "workspace:*",
    "@bcp/internal": "workspace:*",
    "@bcp/sdk": "workspace:*",
    "@oclif/core": "^4.4.0",
    "@oclif/parser": "^3.8.17",
    "async": "^3.2.6",
    "diff": "^8.0.2",
    "p-limit": "^6.2.0",
    "pino": "^9.14.0",
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "@types/async": "^3.2.24"
  }
}
