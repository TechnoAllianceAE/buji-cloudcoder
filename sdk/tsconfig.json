{
  "compilerOptions": {
    "target": "ES2023",
    "lib": [
      "ES2023",
      "DOM"
    ],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": true,
    "outDir": "./dist",
    "allowImportingTsExtensions": false,
    "types": [
      "node"
    ],
    "baseUrl": ".",
    "paths": {
      "@bcp/common/*": [
        "../common/src/*"
      ],
      "@bcp/agent-runtime/*": [
        "../packages/agent-runtime/src/*"
      ],
      "@bcp/internal": [
        "../packages/internal/src/index.ts"
      ],
      "@bcp/internal/*": [
        "../packages/internal/src/*"
      ],
      "@bcp/code-map": [
        "../packages/code-map/src/index.ts"
      ],
      "@bcp/code-map/*": [
        "../packages/code-map/src/*"
      ]
    }
  },
  "include": [
    "src/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}
