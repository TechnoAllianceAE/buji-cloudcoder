{
  "name": "@bcp/cli",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "bin": {
    "bcp-tui": "./bin/bcp"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "dev": "pnpm run prebuild:agents && tsx src/index.tsx --cwd ..",
    "prebuild:agents": "tsx scripts/prebuild-agents.ts",
    "build:binary": "tsx ./scripts/build-binary.ts bcp $npm_package_version",
    "release": "tsx scripts/release.ts",
    "test": "NODE_ENV=production vitest run",
    "test:tmux-poc": "tsx src/__tests__/tmux-poc.ts",
    "typecheck": "tsc --noEmit -p ."
  },
  "sideEffects": false,
  "dependencies": {
    "@bcp/agent-runtime": "workspace:*",
    "@bcp/common": "workspace:*",
    "@bcp/internal": "workspace:*",
    "@bcp/sdk": "workspace:*",
    "@gravity-ai/api": "^0.1.2",
    "@opentui/core": "0.1.74",
    "@opentui/react": "0.1.74",
    "@tanstack/react-query": "^5.90.12",
    "commander": "^14.0.1",
    "immer": "^10.1.3",
    "jimp": "^1.6.0",
    "open": "^10.1.0",
    "picocolors": "^1.1.1",
    "pino": "9.4.0",
    "react": "^19.0.0",
    "react-reconciler": "^0.32.0",
    "remark-breaks": "^4.0.0",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "string-width": "^7.2.0",
    "systeminformation": "^5.30.7",
    "terminal-image": "^4.1.0",
    "ts-pattern": "^5.9.0",
    "unified": "^11.0.0",
    "yoga-layout": "^3.2.1",
    "zod": "^4.2.1",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@types/react": "19.2.14",
    "@types/react-reconciler": "^0.32.0",
    "react-dom": "^19.0.0",
    "strip-ansi": "^7.1.2"
  }
}
